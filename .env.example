# Notion
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROJECTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Leave empty — the bot auto-captures the target when you message it / add to a group.
# Or set it to a userId (U...) or groupId (C...) to force a specific destination.
LINE_TARGET_ID=

# App
TIMEZONE=Asia/Bangkok
PORT=3000
PUBLIC_BASE_URL=https://your-app.onrender.com

# Cron schedules (24h, in TIMEZONE). Used by in-process cron.
CRON_MORNING=30 7 * * *
CRON_EVENING=0 21 * * *
CRON_REMINDER=*/5 * * * *
REMINDER_LEAD_MINUTES=30

# On free hosts that sleep (e.g. Render free), set this to 1 and trigger the
# /cron/* endpoints from a free external scheduler (cron-job.org).
DISABLE_INPROCESS_CRON=0

# Secret protecting the /cron/* HTTP trigger endpoints
CRON_SECRET=change-me-to-a-random-string
